{
  "name": "microsoft-todo-safe-mcp",
  "version": "1.1.3",
  "description": "Local-first Microsoft To Do MCP server with safe AI plan validation, preview, backup, confirmation, and audit logs.",
  "main": "dist/todo-index.js",
  "dependencies": {
    "@azure/msal-node": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.21.1",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "zod": "^3.25.76"
  },
  "scripts": {
    "test": "node --test --experimental-strip-types scripts/*.test.ts",
    "test:doctor": "node --test --experimental-strip-types scripts/doctor.test.ts",
    "doctor": "node --experimental-strip-types scripts/doctor.ts",
    "auth:device": "node --experimental-strip-types scripts/auth-device.ts",
    "build": "tsup",
    "build:win": "tsup && node -e \"console.log('Build complete')\"",
    "start": "node dist/todo-index.js",
    "cli": "node dist/cli.js",
    "auth": "node dist/auth-server.js",
    "setup": "node dist/setup.js",
    "dev": "pnpm run build && node dist/cli.js",
    "create-config": "node dist/create-mcp-config.js",
    "format": "prettier --write \"src/**/*.{ts,js,json}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\" \"*.{json,md}\"",
    "lint": "pnpm run format:check",
    "typecheck": "tsc --noEmit",
    "typecheck:doctor": "tsc --noEmit --module Node16 --moduleResolution Node16 --target ES2022 --strict --skipLibCheck --allowImportingTsExtensions scripts/doctor.ts scripts/doctor.test.ts scripts/auth-device.ts scripts/auth-device.test.ts scripts/oauth-refresh.test.ts scripts/safe-plan.test.ts src/oauth-refresh.ts src/safe-plan.ts",
    "check": "pnpm run format:check && pnpm run typecheck",
    "check:fix": "pnpm run format && pnpm run typecheck",
    "ci": "pnpm run check && pnpm run build",
    "precommit": "pnpm run check:fix && pnpm run build",
    "prepublishOnly": "pnpm run ci",
    "postinstall": "echo 'Run auth:device and doctor before connecting this MCP server to an AI assistant'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Saenai/microsoft-todo-safe-mcp.git"
  },
  "keywords": [
    "mcp",
    "cursor",
    "claude",
    "microsoft-todo",
    "todo"
  ],
  "author": "Saenai",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Saenai/microsoft-todo-safe-mcp/issues"
  },
  "homepage": "https://github.com/Saenai/microsoft-todo-safe-mcp#readme",
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^22.19.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "type": "module",
  "bin": {
    "microsoft-todo-safe-mcp": "./dist/cli.js",
    "microsoft-todo-mcp-server": "./dist/cli.js",
    "mstodo": "./dist/cli.js",
    "mstodo-config": "./dist/create-mcp-config.js",
    "mstodo-setup": "./dist/setup.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.21.0+sha512.da3337267e400fdd3d479a6c68079ac6db01d8ca4f67572083e722775a796788a7a9956613749e000fac20d424b594f7a791a5f4e2e13581c5ef947f26968a40"
}
